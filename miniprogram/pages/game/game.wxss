.status-card {
  background: linear-gradient(135deg, #fffaf0, #fff0d2);
  border-color: #ff385c;
}

.roll-box {
  background: #fff4d6;
  border: 2rpx solid rgba(122, 76, 43, 0.14);
  border-radius: 24rpx;
  line-height: 1.5;
  margin: 18rpx 0;
  padding: 20rpx;
}

.roll-total, .player-name, .score, .section-title {
  font-weight: 800;
}

.section-title {
  font-size: 34rpx;
  letter-spacing: -1rpx;
  margin-bottom: 12rpx;
}

.section-subtitle {
  color: #6a5a47;
  font-size: 26rpx;
  font-weight: 800;
  margin: 22rpx 0 12rpx;
}

.warning {
  color: #b83220;
  font-weight: 800;
  margin-top: 8rpx;
}

.phase-hint {
  background: rgba(47, 125, 89, 0.1);
  border: 2rpx solid rgba(47, 125, 89, 0.18);
  border-radius: 18rpx;
  color: #315f4f;
  font-size: 26rpx;
  font-weight: 800;
  margin: 14rpx 0;
  padding: 14rpx 16rpx;
}

.winner {
  background: linear-gradient(135deg, #2f7d59, #55aa73);
  border-radius: 22rpx;
  color: #fff;
  font-weight: 800;
  margin: 18rpx 0;
  padding: 20rpx;
}

.mode-row, .award-row, .piece-legend {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin: 18rpx 0;
}

.piece-legend {
  background: rgba(255, 255, 255, 0.78);
  border: 2rpx solid rgba(122, 76, 43, 0.12);
  border-radius: 24rpx;
  padding: 16rpx;
}

.piece-legend view {
  align-items: center;
  background: #fffaf0;
  border-radius: 999rpx;
  color: #222;
  display: inline-flex;
  font-size: 24rpx;
  font-weight: 800;
  gap: 8rpx;
  padding: 10rpx 16rpx;
}

.piece-icon {
  align-items: center;
  border-radius: 999rpx;
  display: inline-flex;
  height: 38rpx;
  justify-content: center;
  width: 38rpx;
}

.settlement-icon { background: #ffebe8; }
.road-icon { background: #e9f3ff; }
.city-icon { background: #eee9ff; }
.robber-icon { background: #222; color: #fff; }

.active-mode {
  background: linear-gradient(135deg, #ff385c, #d92d4f);
  color: #fff;
}

.hex-scroll {
  white-space: nowrap;
  width: 100%;
}

.hex-strip {
  display: flex;
  gap: 14rpx;
  padding: 14rpx 0;
}

.hex-chip {
  align-items: center;
  border: 4rpx solid rgba(255,255,255,0.88);
  border-radius: 26rpx;
  box-shadow: 0 10rpx 18rpx rgba(61, 43, 31, 0.16);
  color: #222;
  display: inline-flex;
  flex-direction: column;
  font-size: 24rpx;
  font-weight: 800;
  gap: 8rpx;
  min-width: 162rpx;
  padding: 18rpx 16rpx;
  text-align: center;
  text-transform: capitalize;
}

.resource-badge {
  align-items: center;
  background: rgba(255,255,255,0.82);
  border-radius: 999rpx;
  display: inline-flex;
  font-size: 36rpx;
  height: 58rpx;
  justify-content: center;
  width: 58rpx;
}

.resource-brick { background: #c75b39; color: #fff; }
.resource-lumber { background: #2f7d32; color: #fff; }
.resource-wool { background: #9ccc65; }
.resource-grain { background: #f2c94c; }
.resource-ore { background: #8b8f98; color: #fff; }
.resource-desert { background: #d7b46a; }

.point-grid {
  display: grid;
  gap: 12rpx;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  max-height: 360rpx;
  overflow: auto;
}

.point-grid button {
  border-radius: 999rpx;
  font-weight: 700;
}

.log-line {
  border-top: 1rpx solid rgba(122, 76, 43, 0.16);
  color: #6a5a47;
  line-height: 1.4;
  padding: 12rpx 0;
}

.player-card {
  border-left: 12rpx solid #ff385c;
}

.player-header {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.score {
  background: #222;
  border-radius: 999rpx;
  color: #fff;
  padding: 8rpx 16rpx;
}

.resource-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin: 18rpx 0;
}

.resource-cell {
  background: #fff4d6;
  border-radius: 20rpx;
  padding: 16rpx;
}

.resource-name {
  color: #6a5a47;
  font-size: 24rpx;
  font-weight: 800;
  text-transform: capitalize;
}

.counter-row {
  align-items: center;
  display: flex;
  gap: 12rpx;
  justify-content: space-between;
}

.award-button {
  background: #222;
  color: #fff;
}

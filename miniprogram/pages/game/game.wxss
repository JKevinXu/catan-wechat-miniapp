.status-card {
  border-color: #c75b39;
}

.roll-box {
  background: #f2dfb8;
  border-radius: 14rpx;
  line-height: 1.5;
  margin: 18rpx 0;
  padding: 18rpx;
}

.roll-total, .player-name, .score {
  font-weight: 700;
}

.warning {
  color: #b83220;
  font-weight: 700;
  margin-top: 8rpx;
}

.winner {
  background: #4d7c59;
  border-radius: 14rpx;
  color: #fff;
  font-weight: 700;
  margin: 18rpx 0;
  padding: 18rpx;
}

.player-header {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.resource-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin: 18rpx 0;
}

.resource-cell {
  background: #f2dfb8;
  border-radius: 14rpx;
  padding: 14rpx;
}

.resource-name {
  color: #6f4e37;
  font-size: 24rpx;
  text-transform: capitalize;
}

.counter-row, .counter-line, .award-row {
  align-items: center;
  display: flex;
  gap: 12rpx;
}

.counter-row {
  justify-content: space-between;
}

.counter-line {
  border-top: 1rpx solid #e7d4b5;
  justify-content: space-between;
  padding: 12rpx 0;
}

.counter-line text {
  flex: 1;
}

.award-row {
  flex-wrap: wrap;
  margin-top: 14rpx;
}

.award-button {
  background: #6f4e37;
  color: #fff;
}

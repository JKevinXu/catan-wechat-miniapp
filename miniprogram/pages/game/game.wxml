<view class="container">
  <view class="card status-card">
    <view class="title">{{currentPlayer.name}}'s turn</view>
    <view class="subtitle">Phase: {{game.phase}} · Mode: {{mode}}</view>
    <view wx:if="{{game.lastRoll}}" class="roll-box">
      <view class="roll-total">Roll: {{game.lastRoll.dieA}} + {{game.lastRoll.dieB}} = {{game.lastRoll.total}}</view>
      <view>{{game.lastRoll.message}}</view>
      <view wx:if="{{discardCandidateNames}}" class="warning">Discard candidates: {{discardCandidateNames}}</view>
    </view>
    <view wx:if="{{winner}}" class="winner">{{winner.name}} reached 10+ points!</view>
    <button class="primary-button" disabled="{{!isRollPhase || isGameOver}}" bindtap="roll">Roll dice</button>
    <button class="secondary-button" disabled="{{isGameOver}}" bindtap="endTurn">End turn</button>
    <button bindtap="openRules">Rules</button>
  </view>

  <view class="card board-card">
    <view class="section-title">Playable Board</view>
    <view class="subtitle">Tap the board directly: empty points build settlements, owned settlements upgrade to cities, edges build roads, and tiles move the robber. Use free setup while learning.</view>
    <view class="piece-legend">
      <view><text class="piece-icon settlement-icon">🏠</text> Settlement</view>
      <view><text class="piece-icon road-icon">🛣️</text> Road</view>
      <view><text class="piece-icon city-icon">🏙️</text> City</view>
      <view><text class="piece-icon robber-icon">●</text> Robber</view>
    </view>

    <view class="mode-row">
      <button size="mini" bindtap="toggleFreeBuild">{{freeBuild ? 'Free setup: on' : 'Free setup: off'}}</button>
    </view>

    <scroll-view scroll-x class="hex-scroll">
      <view class="hex-strip">
        <view wx:for="{{boardHexes}}" wx:key="id" class="hex-chip resource-{{item.resource}}" data-hex-id="{{item.id}}" bindtap="tapHex">
          <text class="resource-badge">{{item.icon}}</text>
          <text>{{item.label}}{{item.robberLabel}}</text>
        </view>
      </view>
    </scroll-view>

    <view class="section-subtitle">Build points</view>
    <view class="point-grid">
      <button wx:for="{{boardVertices}}" wx:key="id" size="mini" data-vertex-id="{{item.id}}" bindtap="tapVertex">{{item.id}} {{item.label}}</button>
    </view>

    <view class="section-subtitle">Road edges</view>
    <view class="point-grid">
      <button wx:for="{{boardEdges}}" wx:key="id" size="mini" data-edge-id="{{item.id}}" bindtap="tapEdge">{{item.id}} {{item.label}}</button>
    </view>
  </view>

  <view class="card">
    <view class="section-title">Game Log</view>
    <view wx:for="{{log}}" wx:key="*this" class="log-line">{{item}}</view>
  </view>

  <view wx:for="{{players}}" wx:key="id" class="card player-card">
    <view class="player-header">
      <view class="player-name">{{item.name}}</view>
      <view class="score">{{item.score}} VP</view>
    </view>
    <view class="muted">Roads {{item.roads}} · Settlements {{item.settlements}} · Cities {{item.cities}} · Resources {{item.resourceTotal}}</view>

    <view class="resource-grid">
      <view wx:for="{{item.resourceRows}}" wx:for-item="resource" wx:key="name" class="resource-cell">
        <view class="resource-name">{{resource.name}}</view>
        <view class="counter-row">
          <button size="mini" data-player-id="{{item.id}}" data-resource="{{resource.name}}" data-delta="-1" bindtap="adjustResource">-</button>
          <text>{{resource.count}}</text>
          <button size="mini" data-player-id="{{item.id}}" data-resource="{{resource.name}}" data-delta="1" bindtap="adjustResource">+</button>
        </view>
      </view>
    </view>

    <view class="award-row">
      <button size="mini" class="award-button" data-player-id="{{item.id}}" bindtap="toggleLongestRoad">{{item.hasLongestRoad ? 'Remove Longest Road' : 'Set Longest Road'}}</button>
      <button size="mini" class="award-button" data-player-id="{{item.id}}" bindtap="toggleLargestArmy">{{item.hasLargestArmy ? 'Remove Largest Army' : 'Set Largest Army'}}</button>
    </view>
  </view>
</view>

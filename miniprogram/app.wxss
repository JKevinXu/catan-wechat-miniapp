page {
  background: #f7ead0;
  color: #3d2b1f;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
}

.container {
  padding: 28rpx;
}

.card {
  background: #fff8e8;
  border: 2rpx solid #d6b37a;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 20rpx rgba(61, 43, 31, 0.08);
  margin-bottom: 24rpx;
  padding: 24rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.subtitle {
  color: #6f4e37;
  font-size: 28rpx;
  line-height: 1.5;
}

.primary-button {
  background: #c75b39;
  border-radius: 14rpx;
  color: #fff;
  margin: 20rpx 0 0;
}

.secondary-button {
  background: #4d7c59;
  border-radius: 14rpx;
  color: #fff;
  margin: 20rpx 0 0;
}

.muted {
  color: #8a7058;
}
